{% comment %}
  TASK: 09 — Etiquetas dinâmicas (metaobject): título + cores de fundo/texto no card.
  Metacampo: lista `custom.custom_label` (fallback `custom.product_labels`). Até 3 entradas com título no card.
  Parâmetros: card_product, section_id, badge_id_prefix
  Cores: objeto Color da Shopify — .rgb como "r g b" → rgb(r g b).
{% endcomment %}
{% liquid
  assign rendered = 0
  assign labels = card_product.metafields.custom.custom_label.value
  if labels == blank
    assign labels = card_product.metafields.custom.product_labels.value
  endif
%}
{% for label in labels %}
  {% assign t = label.title.value | default: label.title | strip %}
  {% if t != blank %}
    {% assign rendered = rendered | plus: 1 %}
    {% if rendered <= 3 %}
      {% liquid
        assign bg = label.background_color.value | default: label.background_color
        assign fg = label.text_color.value | default: label.text_color
        assign bg_css = 'rgb(51 51 51)'
        assign fg_css = 'rgb(255 255 255)'
        if bg != blank
          if bg.rgb != blank
            assign bg_css = 'rgb(' | append: bg.rgb | append: ')'
          else
            assign bg_css = bg | append: ''
          endif
        endif
        if fg != blank
          if fg.rgb != blank
            assign fg_css = 'rgb(' | append: fg.rgb | append: ')'
          else
            assign fg_css = fg | append: ''
          endif
        endif
      %}
      {% liquid
        assign badge_id = badge_id_prefix | append: '-' | append: section_id | append: '-' | append: card_product.id
        if rendered > 1
          assign badge_id = badge_id | append: '-' | append: rendered
        endif
      %}
      <span
        id="{{ badge_id }}"
        class="badge badge--bottom-left card-product-custom-label"
        style="background-color: {{ bg_css }}; color: {{ fg_css }};"
      >
        {{- t | escape -}}
      </span>
    {% endif %}
  {% endif %}
{% endfor %}
