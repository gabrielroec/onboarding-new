{% comment %}
  TASK: 06 — Produtos relacionados no artigo (metacampo `article.metafields.custom.related_products`, lista de produtos, máx. 4).
  Só produz HTML se houver pelo menos um produto. Layout tipo Coleção em destaque / carrossel.
  @param article {Article}
  @param cfg {object} section.settings ou block.settings (mesmas chaves da secção article-related-products)
  @param dom_id {String} identificador único para IDs do slider
{% endcomment %}
{%- liquid
  assign mf = article.metafields.custom.related_products
  assign related_raw = mf.value
  assign item_count = 0

  if mf != blank and related_raw != blank
    for p in related_raw
      if item_count >= 4
        break
      endif
      if p != blank
        assign item_count = item_count | plus: 1
      endif
    endfor
  endif

  assign columns_mobile_int = cfg.columns_mobile | plus: 0
  assign columns_desktop_int = cfg.columns_desktop | plus: 0
  assign show_mobile_slider = false
  if cfg.swipe_on_mobile and item_count > columns_mobile_int
    assign show_mobile_slider = true
  endif

  assign show_desktop_slider = false
  if cfg.enable_desktop_slider and item_count > columns_desktop_int
    assign show_desktop_slider = true
  endif

  assign max_columns_to_show = columns_mobile_int
  if columns_desktop_int > columns_mobile_int
    assign max_columns_to_show = columns_desktop_int
  endif
-%}

{%- if item_count > 0 -%}
  {{ 'component-card.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'template-collection.css' | asset_url | stylesheet_tag }}

  {% if cfg.image_shape == 'blob' %}
    {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- unless cfg.quick_add == 'none' -%}
    {{ 'quick-add.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {%- endunless -%}

  {%- if cfg.quick_add == 'standard' -%}
    <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if cfg.quick_add == 'bulk' -%}
    <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
  {%- style -%}
    .article-related-inner-{{ dom_id }} {
      padding-top: {{ cfg.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ cfg.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .article-related-inner-{{ dom_id }} {
        padding-top: {{ cfg.padding_top }}px;
        padding-bottom: {{ cfg.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <div class="color-{{ cfg.color_scheme }} isolate gradient">
    <div
      class="collection{% if cfg.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %} article-related-inner-{{ dom_id }}{% if cfg.full_width %} collection--full-width{% endif %}"
      id="article-related-{{ dom_id }}"
    >
      <div
        class="collection__title title-wrapper title-wrapper--no-top-margin page-width{% if show_mobile_slider %} title-wrapper--self-padded-tablet-down{% endif %}{% if show_desktop_slider %} collection__title--desktop-slider{% endif %}"
      >
        {%- if cfg.title != blank -%}
          <h2 class="title inline-richtext {{ cfg.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ cfg.title }}
          </h2>
        {%- endif -%}
      </div>

      <slider-component
        class="slider-mobile-gutter{% if cfg.full_width %} slider-component-full-width{% endif %}{% if show_desktop_slider == false and cfg.full_width == false %} page-width page-width-desktop{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      >
        <ul
          id="Slider-{{ dom_id }}"
          data-id="{{ dom_id }}"
          class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ cfg.columns_desktop }}-col-desktop grid--{{ cfg.columns_mobile }}-col-tablet-down{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
          role="list"
          aria-label="{{ 'general.slider.name' | t }}"
        >
          {% assign skip_card_product_styles = false %}
          {% assign lazy_load = false %}
          {% assign rendered = 0 %}

          {%- for product in related_raw -%}
            {%- if rendered >= 4 -%}
              {%- break -%}
            {%- endif -%}
            {%- if product != blank -%}
              {% if lazy_load == false and forloop.index > max_columns_to_show %}
                {% assign lazy_load = true %}
              {% endif %}
              <li
                id="Slide-{{ dom_id }}-{{ rendered | plus: 1 }}"
                class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ rendered | plus: 1 }};"
                {% endif %}
              >
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: cfg.image_ratio,
                  image_shape: cfg.image_shape,
                  lazy_load: lazy_load,
                  show_secondary_image: cfg.show_secondary_image,
                  show_vendor: cfg.show_vendor,
                  show_rating: cfg.show_rating,
                  skip_styles: skip_card_product_styles,
                  section_id: dom_id,
                  quick_add: cfg.quick_add
                %}
              </li>
              {% assign skip_card_product_styles = true %}
              {% assign rendered = rendered | plus: 1 %}
            {%- endif -%}
          {%- endfor -%}
        </ul>

        {%- if show_mobile_slider or show_desktop_slider -%}
          <div class="slider-buttons">
            <button
              type="button"
              class="slider-button slider-button--prev"
              name="previous"
              aria-label="{{ 'general.slider.previous_slide' | t }}"
              aria-controls="Slider-{{ dom_id }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </button>
            <div class="slider-counter caption">
              <span class="slider-counter--current">1</span>
              <span aria-hidden="true"> / </span>
              <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
              <span class="slider-counter--total">{{ item_count }}</span>
            </div>
            <button
              type="button"
              class="slider-button slider-button--next"
              name="next"
              aria-label="{{ 'general.slider.next_slide' | t }}"
              aria-controls="Slider-{{ dom_id }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>
        {%- endif -%}
      </slider-component>

      {% if cfg.image_shape == 'arch' %}
        {{ 'mask-arch.svg' | inline_asset_content }}
      {%- endif -%}
    </div>
  </div>
{%- endif -%}
